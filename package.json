{
  "name": "agentlint",
  "version": "0.1.0",
  "description": "AGENTS.md defines the rules. AgentLint enforces them.",
  "type": "module",
  "bin": {
    "agentlint": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "rules",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/__tests__/*.test.js",
    "test:build": "tsc && node --test dist/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentlint",
    "agent-skills",
    "agents-md",
    "ai-coding",
    "verification",
    "linting"
  ],
  "author": "LeonTing1010",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeonTing1010/agentlint.git"
  },
  "homepage": "https://github.com/LeonTing1010/agentlint#readme",
  "bugs": {
    "url": "https://github.com/LeonTing1010/agentlint/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
